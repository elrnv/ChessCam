# Build-time Lichess OAuth settings
VITE_LICHESS_CLIENT_ID=chesscam.example.com
VITE_LICHESS_HOST=https://lichess.org

# Local app port when running without the Caddy TLS profile
APP_PORT=8001

# HTTPS deployment with: docker compose --profile tls up -d --build
CHESSCAM_SITE_ADDRESS=chesscam.example.com
HTTP_PORT=80
HTTPS_PORT=443
