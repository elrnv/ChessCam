# Docker Compose reads this file and passes these as Docker build args.
# Dockerfile does not read .env directly or define the app-specific defaults.
#
# Build-time Lichess OAuth settings
VITE_LICHESS_CLIENT_ID=chesscam.example.com
VITE_LICHESS_HOST=https://lichess.org

# Local app address exposed for your host reverse proxy
APP_HOST=127.0.0.1
APP_PORT=8001
